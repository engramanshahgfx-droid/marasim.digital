# ==================================
# SUPABASE CONFIGURATION
# ==================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_public_...
SUPABASE_SERVICE_ROLE_KEY=sbprivate_...

# ==================================
# STRIPE CONFIGURATION
# ==================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ==================================
# TWILIO CONFIGURATION
# ==================================

# Twilio Account Credentials
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...

# Twilio Verify Service (OTP/Phone Verification)
# Get SID from: https://console.twilio.com/develop/verify/services
TWILIO_VERIFY_SERVICE_SID=VA...

# Twilio Phone Numbers (for SMS/Voice)
TWILIO_PHONE_NUMBER=+1234567890

# Twilio WhatsApp Sender (optional, for WhatsApp messaging)
# Set to Sandbox: +14155238886 or your verified WhatsApp Business Number
TWILIO_WHATSAPP_NUMBER=+14155238886

# Twilio WhatsApp Template SID (optional, for template messages)
TWILIO_INVITATION_TEMPLATE_SID=HX...

# ==================================
# EMAIL SERVICE CONFIGURATION (Resend)
# ==================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Marasim <onboarding@resend.dev>

# ==================================
# AI & ANALYTICS (Optional)
# ==================================
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
ANTHROPIC_API_KEY=...
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
NEXT_PUBLIC_ADSENSE_ID=...
PERPLEXITY_API_KEY=...

# ==================================
# APP CONFIGURATION
# ==================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

